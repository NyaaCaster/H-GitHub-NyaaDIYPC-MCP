# ============================================================
# NyaaDIYPC-MCP 环境变量模板
# 复制为 .env 并填入真实值；.env 不入 Git！
# ============================================================

# ---- MCP 服务 ----
MCP_PORT=5115
MCP_HOST=0.0.0.0
MCP_API_KEY=
# 多 token 支持（对标 NyaaQiny-MCP）：以下每个 key 也是有效 token
#MCP_API_KEY_NYAACLI=
#MCP_API_KEY_PUBLIC=
#MCP_API_KEY_FRIENDS=
TZ=Asia/Shanghai

# ---- 私有仓库（禁硬编码！构建时注入）----
PRIVATE_DOCKER_REGISTRY_HOST=

# ---- 数据 ----
DIYPC_DB_PATH=/app/data/diypc.db

# ---- 爬虫 ----
CRAWL_CRON=0 4 * * *
DEEP_TOP_N=300
CRAWL_CONCURRENCY=2
CRAWL_MIN_INTERVAL_S=1.0

# ---- best-price 补价（P3 启用）----
BESTPRICE_MCP_URL=
RT_PRICE_TTL_H=6

# ---- 计算常量（可覆盖）----
CPU_FACTOR=1.3
BASE_LOAD_W=80
PSU_HARD_MARGIN=1.3
PSU_RECOMMEND_MARGIN=1.5
GPU_LEN_SAFETY_MM=10
COOLER_H_SAFETY_MM=10

# ---- 搭配常量（可覆盖）----
REPAIR_MAX_ITER=5
CONVERGE_MAX_ITER=6
CANDIDATE_PRICE_SLACK=1.25
PLAN_COUNT=3
DEFAULT_BUDGET_PROFILE=gaming
